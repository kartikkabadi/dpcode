{
  "name": "@t3tools/desktop",
  "version": "0.0.29",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "bun run scripts/dev.mjs",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "build": "tsdown",
    "start": "bun run scripts/start-electron.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke-test": "node scripts/smoke-test.mjs",
    "build:native": "node-gyp rebuild --directory native/liquidglass"
  },
  "dependencies": {
    "effect": "catalog:",
    "electron": "40.6.0",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@t3tools/contracts": "workspace:*",
    "@t3tools/shared": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wait-on": "^8.0.2",
    "node-addon-api": "^8.4.0",
    "node-gyp": "^11.2.0"
  },
  "productName": "DP Code (Alpha)"
}
